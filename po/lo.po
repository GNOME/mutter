msgstr "ສັບປ່ຽນໄປທີ່ VT 5"

#: data/org.gnome.mutter.wayland.gschema.xml.in:32
msgid "Switch to VT 6"
msgstr "ສັບປ່ຽນໄປທີ່ VT 6"

