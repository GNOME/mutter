msgstr "ສັບປ່ຽນໄປທີ່ພື້ນທີ່ເຮັດວຽກດ້ານເທິງ"

#: data/50-mutter-navigation.xml:142
msgid "Switch to workspace below"
msgstr "ສັບປ່ຽນໄປທີ່ພື້ນທີ່ເຮັດວຽກດ້ານລຸ່ມ"

#: data/50-mutter-system.xml:6 data/50-mutter-wayland.xml:6
msgid "System"
msgstr "ລະບົບ"

#: data/50-mutter-system.xml:8
msgid "Show the run command prompt"
msgstr "ສະແດງກ່ອງຄຳສັ່ງ"

#: data/50-mutter-wayland.xml:8
msgid "Restore the keyboard shortcuts"
msgstr "ກູ້ຄືນປຸ່ມລັດ"

#: data/50-mutter-windows.xml:6
msgid "Windows"
msgstr "ໜ້າຕ່າງ"

#: data/50-mutter-windows.xml:8
msgid "Activate the window menu"
msgstr "ເປີດໃຊ້ເມນູໜ້າຕ່າງ"

#: data/50-mutter-windows.xml:10
msgid "Toggle fullscreen mode"
msgstr "ສະຫຼັບໂໝດເຕັມຈໍ"

#: data/50-mutter-windows.xml:12
msgid "Toggle maximization state"
msgstr "ສະຫຼັບສະຖານະຂະຫຍາຍໃຫຍ່ສຸດ"

#: data/50-mutter-windows.xml:14
msgid "Maximize window"
msgstr "ຂະຫຍາຍໜ້າຕ່າງໃຫຍ່ສຸດ"

#: data/50-mutter-windows.xml:16
msgid "Restore window"
msgstr "ກູ້ຄືນໜ້າຕ່າງ"

#: data/50-mutter-windows.xml:18
msgid "Close window"
msgstr "ປິດໜ້າຕ່າງ"

#: data/50-mutter-windows.xml:20
msgid "Hide window"
msgstr "ເຊື່ອງໜ້າຕ່າງ"

#: data/50-mutter-windows.xml:22
msgid "Move window"
msgstr "ຍ້າຍໜ້າຕ່າງ"

#: data/50-mutter-windows.xml:24
msgid "Resize window"
msgstr "ປັບຂະໜາດໜ້າຕ່າງ"

#: data/50-mutter-windows.xml:27
msgid "Toggle window on all workspaces or one"
msgstr "ສະຫຼັບໜ້າຕ່າງໃນທຸກພື້ນທີ່ເຮັດວຽກ ຫຼື ໜຶ່ງດຽວ"

#: data/50-mutter-windows.xml:29
msgid "Raise window if covered, otherwise lower it"
msgstr "ຍົກໜ້າຕ່າງຂຶ້ນຖ້າຖືກບັງ, ຖ້າບໍ່ດັ່ງນັ້ນໃຫ້ຫຼຸດລົງ"

#: data/50-mutter-windows.xml:31
msgid "Raise window above other windows"
msgstr "ຍົກໜ້າຕ່າງຂຶ້ນເທິງໜ້າຕ່າງອື່ນ"

#: data/50-mutter-windows.xml:33
msgid "Lower window below other windows"
msgstr "ຫຼຸດໜ້າຕ່າງລົງລຸ່ມໜ້າຕ່າງອື່ນ"

#: data/50-mutter-windows.xml:35
msgid "Maximize window vertically"
msgstr "ຂະຫຍາຍໜ້າຕ່າງໃຫຍ່ສຸດຕາມແນວຕັ້ງ"

#: data/50-mutter-windows.xml:37
msgid "Maximize window horizontally"
msgstr "ຂະຫຍາຍໜ້າຕ່າງໃຫຍ່ສຸດຕາມແນວນອນ"

#: data/50-mutter-windows.xml:41 data/org.gnome.mutter.gschema.xml.in:187
msgid "View split on left"
msgstr "ເບິ່ງແບບແບ່ງຊ້າຍ"

#: data/50-mutter-windows.xml:45 data/org.gnome.mutter.gschema.xml.in:192
msgid "View split on right"
msgstr "ເບິ່ງແບບແບ່ງຂວາ"

#: data/org.gnome.mutter.gschema.xml.in:16
msgid "Modifier to use for extended window management operations"
msgstr "ປຸ່ມດັດແປງທີ່ຈະໃຊ້ສຳລັບການດຳເນີນການຈັດການໜ້າຕ່າງແບບຂະຫຍາຍ"

#: data/org.gnome.mutter.gschema.xml.in:17
msgid ""
"This key will initiate the “overlay”, which is a combination window overview "
"and application launching system. The default is intended to be the “Windows "
"key” on PC hardware. It’s expected that this binding either the default or "
"set to the empty string."
msgstr "ປຸ່ມນີ້ຈະເລີ່ມ “ໂອເວີເລ”, ເຊິ່ງເປັນການລວມກັນລະຫວ່າງພາບລວມຂອງໜ້າຕ່າງ ແລະ ລະບົບເປີດແອັບພລິເຄຊັນ. ຄ່າເລີ່ມຕົ້ນຕັ້ງໃຈໃຫ້ເປັນ “ປຸ່ມ Windows” ເທິງຮາດແວຂອງ PC. ຄາດວ່າການກຳນົດຄ່ານີ້ຈະເປັນຄ່າເລີ່ມຕົ້ນ ຫຼື ຕັ້ງເປັນຄ່າວ່າງ."

#: data/org.gnome.mutter.gschema.xml.in:29
msgid "Attach modal dialogs"
msgstr "ຕິດກ່ອງໂຕ້ຕອບໂມດໍ"

#: data/org.gnome.mutter.gschema.xml.in:30
msgid ""
"When true, instead of having independent titlebars, modal dialogs appear "
"attached to the titlebar of the parent window and are moved together with "
"the parent window."
msgstr "ເມື່ອເປັນຈິງ, ແທນທີ່ຈະມີແຖບຫົວເລື່ອງທີ່ເປັນເອກະລາດ, ກ່ອງໂຕ້ຕອບໂມດໍຈະປະກົດຕິດຢູ່ກັບແຖບຫົວເລື່ອງຂອງໜ້າຕ່າງຫຼັກ ແລະ ຖືກຍ້າຍໄປພ້ອມກັບໜ້າຕ່າງຫຼັກ."

#: data/org.gnome.mutter.gschema.xml.in:39
msgid "Enable edge tiling when dropping windows on screen edges"
msgstr "ເປີດໃຊ້ການຈັດລຽນຕາມຂອບ ເມື່ອລາກໜ້າຕ່າງໃສ່ຂອບຈໍ"

#: data/org.gnome.mutter.gschema.xml.in:40
msgid ""
"If enabled, dropping windows on vertical screen edges maximizes them "
"vertically and resizes them horizontally to cover half of the available "
"area. Dropping windows on the top screen edge maximizes them completely."
msgstr "ຖ້າເປີດໃຊ້, ການລາກໜ້າຕ່າງມາໃສ່ຂອບຈໍແນວຕັ້ງຈະຂະຫຍາຍພວກມັນໃຫຍ່ສຸດຕາມແນວຕັ້ງ ແລະ ປັບຂະໜາດຕາມແນວນອນເພື່ອໃຫ້ກວມເອົາເຄິ່ງໜຶ່ງຂອງພື້ນທີ່ທີ່ມີຢູ່. ການລາກໜ້າຕ່າງມາໃສ່ຂອບຈໍດ້ານເທິງຈະຂະຫຍາຍພວກມັນໃຫຍ່ສຸດເຕັມຈໍ."

#: data/org.gnome.mutter.gschema.xml.in:49
msgid "Workspaces are managed dynamically"
msgstr "ພື້ນທີ່ເຮັດວຽກຖືກຈັດການແບບໄດນາມິກ"

#: data/org.gnome.mutter.gschema.xml.in:50
msgid ""
"Determines whether workspaces are managed dynamically or whether there’s a "
"static number of workspaces (determined by the num-workspaces key in "
"org.gnome.desktop.wm.preferences)."
msgstr "ກຳນົດວ່າພື້ນທີ່ເຮັດວຽກຈະຖືກຈັດການແບບໄດນາມິກ ຫຼື ຈະມີຈຳນວນພື້ນທີ່ເຮັດວຽກຄົງທີ່ (ກຳນົດໂດຍຄີ num-workspaces ໃນ org.gnome.desktop.wm.preferences)."

#: data/org.gnome.mutter.gschema.xml.in:59
msgid "Workspaces only on primary"
msgstr "ພື້ນທີ່ເຮັດວຽກສະເພາະໃນຈໍຫຼັກ"

#: data/org.gnome.mutter.gschema.xml.in:60
msgid ""
"Determines whether workspace switching should happen for windows on all "
"monitors or only for windows on the primary monitor."
msgstr "ກຳນົດວ່າການສັບປ່ຽນພື້ນທີ່ເຮັດວຽກຄວນເກີດຂຶ້ນສຳລັບໜ້າຕ່າງໃນທຸກຈໍພາບ ຫຼື ສະເພາະໜ້າຕ່າງໃນຈໍພາບຫຼັກເທົ່ານັ້ນ."

#: data/org.gnome.mutter.gschema.xml.in:68
msgid "Delay focus changes until the pointer stops moving"
msgstr "ຊັກຊ້າການປ່ຽນໂຟກັສຈົນກວ່າຕົວຊີ້ຈະຢຸດເຄື່ອນທີ່"

#: data/org.gnome.mutter.gschema.xml.in:69
msgid ""
"If set to true, and the focus mode is either “sloppy” or “mouse” then the "
"focus will not be changed immediately when entering a window, but only after "
"the pointer stops moving."
msgstr "ຖ້າຕັ້ງເປັນຈິງ, ແລະ ໂໝດໂຟກັສເປັນ “sloppy” ຫຼື “mouse” ໂຟກັສຈະບໍ່ຖືກປ່ຽນທັນທີເມື່ອເຂົ້າສູ່ໜ້າຕ່າງ, ແຕ່ຈະປ່ຽນຫຼັງຈາກຕົວຊີ້ຢຸດເຄື່ອນທີ່ເທົ່ານັ້ນ."

#: data/org.gnome.mutter.gschema.xml.in:79
msgid "Draggable border width"
msgstr "ຄວາມກວ້າງຂອງຂອບທີ່ລາກໄດ້"

#: data/org.gnome.mutter.gschema.xml.in:80
msgid ""
"The amount of total draggable borders. If the theme’s visible borders are "
"not enough, invisible borders will be added to meet this value."
msgstr "ປະລິມານຂອງຂອບທັງໝົດທີ່ລາກໄດ້. ຖ້າຂອບທີ່ເຫັນໄດ້ຂອງທີມບໍ່ພຽງພໍ, ຂອບທີ່ເບິ່ງບໍ່ເຫັນຈະຖືກເພີ່ມເຂົ້າເພື່ອໃຫ້ໄດ້ຄ່ານີ້."

#: data/org.gnome.mutter.gschema.xml.in:89
msgid "Auto maximize nearly monitor sized windows"
msgstr "ຂະຫຍາຍໜ້າຕ່າງຂະໜາດເກືອບເທົ່າຈໍພາບໃຫຍ່ສຸດໂດຍອັດຕະໂນມັດ"

#: data/org.gnome.mutter.gschema.xml.in:90
msgid ""
"If enabled, new windows that are initially the size of the monitor "
"automatically get maximized."
msgstr "ຖ້າເປີດໃຊ້, ໜ້າຕ່າງໃໝ່ທີ່ມີຂະໜາດເທົ່າກັບຈໍພາບໃນເບື້ອງຕົ້ນຈະຖືກຂະຫຍາຍໃຫຍ່ສຸດໂດຍອັດຕະໂນມັດ."

#: data/org.gnome.mutter.gschema.xml.in:98
msgid "Place new windows in the center"
msgstr "ວາງໜ້າຕ່າງໃໝ່ໄວ້ກາງຈໍ"

#: data/org.gnome.mutter.gschema.xml.in:99
msgid ""
"When true, the new windows will always be put in the center of the active "
"screen of the monitor."
msgstr "ເມື່ອເປັນຈິງ, ໜ້າຕ່າງໃໝ່ຈະຖືກວາງໄວ້ກາງຈໍທີ່ໃຊ້ງານຢູ່ສະເໝີ."

#: data/org.gnome.mutter.gschema.xml.in:108
msgid "Enable experimental features"
msgstr "ເປີດໃຊ້ຄຸນສົມບັດທົດລອງ"

#: data/org.gnome.mutter.gschema.xml.in:109
msgid ""
"To enable experimental features, add the feature keyword to the list. "
"Whether the feature requires restarting the compositor depends on the given "
"feature. Any experimental feature is not required to still be available, or "
"configurable. Don’t expect adding anything in this setting to be future "
"proof. Currently possible keywords: • “scale-monitor-framebuffer” — makes "
"mutter default to layout logical monitors in a logical pixel coordinate "
"space, while scaling monitor framebuffers instead of window content, to "
"manage HiDPI monitors. Does not require a restart. • “kms-modifiers” — makes "
"mutter always allocate scanout buffers with explicit modifiers, if supported "
"by the driver. Requires a restart. • “autoclose-xwayland” — automatically "
"terminates Xwayland if all relevant X11 clients are gone. Requires a "
"restart. • “variable-refresh-rate” — makes mutter dynamically adjust the "
"refresh rate of the monitor when applicable if supported by the monitor, GPU "
"and DRM driver. Configurable in Settings. Requires a restart. • “xwayland-"
"native-scaling” — lets Xwayland clients use their native scaling support. If "
"scaling is not supported by client, the client will be unscaled. Setting "
"only takes effect when “scale-monitor-framebuffer” is enabled as well."
msgstr "ເພື່ອເປີດໃຊ້ຄຸນສົມບັດທົດລອງ, ໃຫ້ເພີ່ມຄີເວີດຄຸນສົມບັດເຂົ້າໃນລາຍການ. ການທີ່ຄຸນສົມບັດຈະຕ້ອງການເປີດຄອມໂພສິເຕີຄືນໃໝ່ຫຼືບໍ່ນັ້ນ ຂຶ້ນຢູ່ກັບຄຸນສົມບັດທີ່ໃຫ້ມາ. ຄຸນສົມບັດທົດລອງໃດໆກໍຕາມບໍ່ຈຳເປັນຕ້ອງມີໃຫ້ໃຊ້ຕໍ່ໄປ, ຫຼື ສາມາດກຳນົດຄ່າໄດ້. ຢ່າຄາດຫວັງວ່າການເພີ່ມສິ່ງໃດໃນການຕັ້ງຄ່ານີ້ຈະປອດໄພໃນອະນາຄົດ. ຄີເວີດທີ່ເປັນໄປໄດ້ໃນປັດຈຸບັນ: • “scale-monitor-framebuffer” — ເຮັດໃຫ້ mutter ຈັດວາງຈໍພາບຕາມເຫດຜົນໃນພື້ນທີ່ພິກັດພິກເຊວຕາມເຫດຜົນເປັນຄ່າເລີ່ມຕົ້ນ, ໃນຂະນະທີ່ຂະຫຍາຍເຟຣມບັບເຟີຂອງຈໍພາບແທນເນື້ອຫາຂອງໜ້າຕ່າງ, ເພື່ອຈັດການຈໍພາບ HiDPI. ບໍ່ຕ້ອງການການເປີດຄືນໃໝ່. • “kms-modifiers” — ເຮັດໃຫ້ mutter ຈັດສັນບັບເຟີສະແກນເອົາດ້ວຍໂຕດັດແປງທີ່ຊັດເຈນສະເໝີ, ຖ້າໄດຣເວີຮອງຮັບ. ຕ້ອງການການເປີດຄືນໃໝ່. • “autoclose-xwayland” — ຢຸດການເຮັດວຽກຂອງ Xwayland ໂດຍອັດຕະໂນມັດຖ້າໄຄລເອັນ X11 ທີ່ກ່ຽວຂ້ອງທັງໝົດໝົດໄປ. ຕ້ອງການການເປີດຄືນໃໝ່. • “variable-refresh-rate” — ເຮັດໃຫ້ mutter ປັບອັດຕາການໂຫຼດໜ້າຈໍຂອງຈໍພາບແບບໄດນາມິກເມື່ອເໝາະສົມ ຖ້າຈໍພາບ, GPU ແລະ ໄດຣເວີ DRM ຮອງຮັບ. ສາມາດກຳນົດຄ່າໄດ້ໃນການຕັ້ງຄ່າ. ຕ້ອງການການເປີດຄືນໃໝ່. • “xwayland-native-scaling” — ໃຫ້ໄຄລເອັນ Xwayland ໃຊ້ການຮອງຮັບການຂະຫຍາຍແບບດັ້ງເດີມຂອງພວກເຂົາ. ຖ້າໄຄລເອັນບໍ່ຮອງຮັບການຂະຫຍາຍ, ໄຄລເອັນຈະບໍ່ຖືກຂະຫຍາຍ. ການຕັ້ງຄ່ານີ້ມີຜົນກະທົບເມື່ອເປີດໃຊ້ “scale-monitor-framebuffer” ເທົ່ານັ້ນ."

#: data/org.gnome.mutter.gschema.xml.in:151
msgid "Modifier to use to locate the pointer"
msgstr "ປຸ່ມດັດແປງທີ່ຈະໃຊ້ເພື່ອຊອກຫາຕົວຊີ້"

#: data/org.gnome.mutter.gschema.xml.in:152
msgid "This key will initiate the “locate pointer” action."
msgstr "ປຸ່ມນີ້ຈະເລີ່ມການກະທຳ “ຊອກຫາຕົວຊີ້”."

#: data/org.gnome.mutter.gschema.xml.in:159
msgid "Timeout for check-alive ping"
msgstr "ໝົດເວລາສຳລັບການພິງເພື່ອກວດສອບການໃຊ້ງານ"

#: data/org.gnome.mutter.gschema.xml.in:160
msgid ""
"Number of milliseconds a client has to respond to a ping request in order to "
"not be detected as frozen. Using 0 will disable the alive check completely."
msgstr "ຈຳນວນມິນລິວິນາທີທີ່ໄຄລເອັນຕ້ອງຕອບສະໜອງຕໍ່ຄຳຂໍພິງເພື່ອບໍ່ໃຫ້ຖືກກວດພົບວ່າຄ້າງ. ການໃຊ້ 0 ຈະປິດການກວດສອບການໃຊ້ງານທັງໝົດ."

#. TRANSLATORS: Luminance is different from brightness.
#. See https://en.wikipedia.org/wiki/Luminance
#: data/org.gnome.mutter.gschema.xml.in:171
msgid "Per output luminance settings"
msgstr "ການຕັ້ງຄ່າຄວາມສະຫວ່າງຕໍ່ເອົາພຸດ"

#: data/org.gnome.mutter.gschema.xml.in:172
msgid ""
"Per output and color mode luminance setting. Each entry consists of a tuple "
"with connector, vendor, product, serial, and a color mode, as well as an "
"associated floating point value representing the output luminance in percent "
"(%). The default when not specified is 100%."
msgstr "ການຕັ້ງຄ່າຄວາມສະຫວ່າງຕໍ່ເອົາພຸດ ແລະ ໂໝດສີ. ແຕ່ລະລາຍການປະກອບດ້ວຍທູເປິລທີ່ມີຕົວເຊື່ອມຕໍ່, ຜູ້ຜະລິດ, ຜະລິດຕະພັນ, ເລກລຳດັບ, ແລະ ໂໝດສີ, ພ້ອມທັງຄ່າຈຸດລອຍທີ່ກ່ຽວຂ້ອງທີ່ສະແດງເຖິງຄວາມສະຫວ່າງຂອງເອົາພຸດເປັນເປີເຊັນ (%). ຄ່າເລີ່ມຕົ້ນເມື່ອບໍ່ໄດ້ລະບຸແມ່ນ 100%."

#: data/org.gnome.mutter.gschema.xml.in:197
msgid "Switch monitor configurations"
msgstr "ສັບປ່ຽນການຕັ້ງຄ່າຈໍພາບ"

#: data/org.gnome.mutter.gschema.xml.in:202
