resize_monitor default 800 600
add_monitor secondary 640 480
set_pref edge-tiling false

new_client w wayland
create w/1 csd
resize w/1 200 200
show w/1

# Maximize

maximize w/1
wait_reconfigure w/1
assert_size w/1 800 600
assert_position w/1 0 0

# Shake loose by dragging downwards

wait_for_effects w/1
move_cursor_to 400 10
click_and_hold
move_cursor_to 400 400 500ms
wait_reconfigure w/1
assert_size w/1 200 200
assert_position w/1 300 396

# Move window back to the top
move_cursor_to 400 10 500ms

# Move window horizontally, to trigger immediate remaximize

move_cursor_to 1000 0 500ms
wait_reconfigure w/1
assert_size w/1 640 480
assert_position w/1 800 0
