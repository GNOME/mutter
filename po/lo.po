msgstr "ສັບປ່ຽນໄປທີ່ VT 2"

#: data/org.gnome.mutter.wayland.gschema.xml.in:20
msgid "Switch to VT 3"
msgstr "ສັບປ່ຽນໄປທີ່ VT 3"

#: data/org.gnome.mutter.wayland.gschema.xml.in:24
